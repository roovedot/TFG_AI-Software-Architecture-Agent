# =============================================================================
# Configuracion del proyecto
# =============================================================================
# ENVIRONMENT=local   → despliega Ollama local (docker compose --profile local up)
# ENVIRONMENT=production → solo APIs de pago (docker compose up)

ENVIRONMENT=local

# ─── LLM ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER es el proveedor por defecto (se puede cambiar por peticion desde el frontend)
LLM_PROVIDER=ollama

# OpenAI (rellenar para usar modelos de OpenAI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini # Modelo por defecto, resto de las opciones se definen en el código

# Anthropic (rellenar para usar modelos de Anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6 # Modelo por defecto, resto de las opciones se definen en el código

# Ollama (modelo local, solo con --profile local)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ─── Embeddings (Fase 2) ────────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ─── MongoDB ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=tfg_architect

# ─── Qdrant ─────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# ─── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=debug

# ─── Frontend ───────────────────────────────────────────────────────────────
API_BASE_URL=http://api:8000

# ─── LangSmith (observabilidad) ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=
LANGSMITH_PROJECT=
