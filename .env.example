# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env.dev or .env.prod and fill in the values.
# Use: docker compose --env-file .env.dev --profile dev up
# Or:  docker compose --env-file .env.prod --profile prod up
# =============================================================================

# Environment: "development" or "production"
ENVIRONMENT=development

# --- LLM Configuration ---

# For production: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# For production: Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# For development: Ollama (local LLM)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Active LLM provider: "openai", "anthropic", or "ollama"
LLM_PROVIDER=ollama

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=debug

# --- LangSmith (Observability) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=tfg-multiagent-architect
